{
  "author": "getquip",
  "bugs": {
    "url": "https://github.com/getquip/expo-nordic-dfu/issues"
  },
  "description": "Nordic DFU for Expo",
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jest": "^29.2.1",
    "eslint-plugin-prettier": "^5.5.4",
    "expo": "~56.0.11",
    "expo-module-scripts": "^56.0.3",
    "prettier": "^3.7.4",
    "react-native": "0.85.3"
  },
  "engines": {
    "node": ">=20.19",
    "npm": ">=10.8"
  },
  "expo-module": {
    "platforms": [
      "ios",
      "android"
    ]
  },
  "homepage": "https://github.com/getquip/expo-nordic-dfu#readme",
  "keywords": [
    "android",
    "dfu",
    "expo",
    "expo-module",
    "ios",
    "nordic",
    "react-native"
  ],
  "license": "MIT",
  "main": "build/index.js",
  "name": "@getquip/expo-nordic-dfu",
  "peerDependencies": {
    "expo": "^56",
    "react": "*",
    "react-native": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "react-native": {
    "codegenConfig": {
      "jsSrcsDir": "src",
      "libraryName": "ExpoNordicDfu",
      "name": "ExpoNordicDfu",
      "type": "modules"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getquip/expo-nordic-dfu.git"
  },
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "expo-module": "expo-module",
    "eslint:check": "eslint . --config eslint.config.mjs --max-warnings 0",
    "eslint:fix": "eslint . --config eslint.config.mjs --fix",
    "open:android": "open -a \"Android Studio\" example/android",
    "open:ios": "xed example/ios",
    "prettier:check": "prettier --config .prettierrc --check '**/*.{ts,tsx,js,jsx}'",
    "prettier:fix": "prettier --config .prettierrc --write '**/*.{ts,tsx,js,jsx}'",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "test": "expo-module test"
  },
  "types": "build/index.d.ts",
  "url": "https://github.com/getquip/expo-nordic-dfu",
  "version": "3.0.2"
}
